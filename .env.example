# Quiver configuration (environment variables).
# Copy to `.env` for local use. Settings are read from defaults, then an optional
# `quiver.toml`, then `QUIVER_*` env vars (ADR-0013), and validated at startup —
# the server refuses to boot on an insecure configuration unless QUIVER_INSECURE
# is set. Commented variables are not yet consumed; they land with their feature.

# --- Server ---
# REST (HTTP/1.1) bind address. Defaults to loopback; a non-loopback bind is
# refused unless QUIVER_INSECURE=true (until TLS lands in the next slice).
QUIVER_REST_ADDR=127.0.0.1:6333
# gRPC (HTTP/2) bind address.
QUIVER_GRPC_ADDR=127.0.0.1:6334
# Data directory for segments, the WAL, and the manifest.
QUIVER_DATA_DIR=./quiver-data
# Accepted API keys, comma-separated. Each is an all-collections ADMIN key.
# Required unless QUIVER_INSECURE=true. For role-based, per-collection scoping
# (ADR-0011), define structured keys in quiver.toml instead:
#
#   [[api_keys]]
#   secret = "readonly-acme-secret"
#   role = "read"              # read | write | admin (admin ⊇ write ⊇ read)
#   collections = ["acme.*"]   # exact names, or a trailing-* prefix; "*" = all
#
# Access is default-deny: a key may only perform its role's actions on the
# collections in its scope, and listing hides everything else.
QUIVER_API_KEYS=replace-with-a-strong-random-key

# --- Encryption at rest (on by default) ---
# 256-bit MASTER key as 64 hex characters. Required unless QUIVER_INSECURE=true.
# It wraps a random per-collection data-encryption key (DEK); each collection's
# segments and index are sealed under its own DEK and the catalog (manifest +
# WAL) under a master-key-derived key, all XChaCha20-Poly1305 (ADR-0010). Because
# the DEK is per-collection, dropping a collection CRYPTO-SHREDS it — the wrapped
# DEK (under <data_dir>/keys/) is destroyed, making its data unrecoverable.
# Generate one with:
#   openssl rand -hex 32
# Source it from a secret store or file — never commit a real key. (NOTE: v0.3.0
# changed the at-rest key hierarchy; re-create encrypted collections from v0.2.0.)
QUIVER_ENCRYPTION_KEY=
# Alternative to QUIVER_ENCRYPTION_KEY (set exactly ONE): read the hex master key
# from a file instead of the environment, so it can be delivered as a mounted
# secret (Docker/Kubernetes) or written by a KMS-decrypt init step. The file
# holds the 64 hex characters (a trailing newline is fine); restrict it to 0600
# (a group/world-readable file is warned about at startup). KMS integration is a
# decrypt-to-file step in front of this — there is no built-in KMS client yet.
# QUIVER_MASTER_KEY_FILE=/run/secrets/quiver-master-key

# --- TLS in transit (ADR-0010) ---
# PEM certificate chain and private key, set together. Required for a
# non-loopback bind unless QUIVER_INSECURE=true. TLS is rustls over the audited
# `ring` provider (no OpenSSL). Generate a dev certificate with, e.g.:
#   openssl req -x509 -newkey rsa:2048 -nodes -days 365 \
#     -keyout key.pem -out cert.pem -subj "/CN=localhost" \
#     -addext "subjectAltName=DNS:localhost,IP:127.0.0.1"
# QUIVER_TLS_CERT=/etc/quiver/tls/cert.pem
# QUIVER_TLS_KEY=/etc/quiver/tls/key.pem
# Optional mutual TLS (ADR-0011): a PEM CA certificate that signs accepted client
# certificates. When set, both transports REQUIRE a client certificate chaining
# to this CA to connect (in addition to the bearer API key). Requires TLS above.
# QUIVER_TLS_CLIENT_CA=/etc/quiver/tls/client-ca.pem

# --- Insecure opt-out (development only) ---
# Disables the secure defaults: allows no API keys, no encryption-at-rest, and a
# non-loopback bind without TLS. Never set this in production.
QUIVER_INSECURE=false

# --- Observability ---
# Log filter, read from RUST_LOG (e.g. info, debug, quiver_server=debug).
RUST_LOG=info
# Prometheus metrics are served at /metrics on the REST listener.
# Append-only audit log (ADR-0011). When set, mutating/admin operations and
# access-control denials are appended as JSON Lines (one record per line);
# records are always also emitted as `quiver::audit` tracing events. A key's
# secret is NEVER written — only its label or a SHA-256 fingerprint. See
# docs/security/audit.md.
# QUIVER_AUDIT_LOG=/var/log/quiver/audit.log

# --- Replication (ADR-0030) ---
# Run this node as a read-replica FOLLOWER: it connects to a leader's gRPC
# endpoint, continuously applies the leader's committed operations, serves reads,
# and REFUSES writes. Unset = a normal read-write leader (which exposes the
# admin-scoped Replicate stream that followers consume). Plaintext to the leader
# for now — run replication over a trusted network. See docs/replication.md.
# QUIVER_LEADER_URL=http://leader-host:6334
# API key the follower presents to the leader's admin-scoped Replicate stream.
# QUIVER_LEADER_API_KEY=

# --- Query cost limits (ADR-0040) ---
# Per-request caps that bound the work any single authenticated request can
# demand, so one oversized request cannot exhaust the single-writer engine.
# Over-limit requests are rejected with HTTP 400 / gRPC InvalidArgument (not
# clamped). Defaults are generous; raise a cap only if a legitimate client needs
# it. The values below are the built-in defaults.
# QUIVER_MAX_K=10000                     # max top-k for search / search_multi_vector
# QUIVER_MAX_EF_SEARCH=4096              # max search beam width
# QUIVER_MAX_FETCH_LIMIT=10000           # max fetch page size
# QUIVER_MAX_VECTOR_DIM=8192             # max collection dimension and query-vector length
# QUIVER_MAX_PAYLOAD_BYTES=65536         # max serialized-JSON payload per point (64 KiB)
# QUIVER_MAX_BATCH_SIZE=1000             # max points / documents per upsert request
# QUIVER_MAX_REQUEST_BODY_BYTES=33554432 # max HTTP request body (32 MiB)

