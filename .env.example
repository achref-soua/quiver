# Quiver configuration (environment variables).
# Copy to `.env` for local use. Every variable is validated at startup once the
# config layer lands (ADR-0013); secure defaults mean an unset value is safe.
# Variables are consumed progressively as Phase 1 features are implemented.

# --- Server ---
# Bind address. Defaults to loopback; a non-loopback bind requires TLS.
QUIVER_BIND_ADDR=127.0.0.1:8080
# gRPC bind address.
QUIVER_GRPC_ADDR=127.0.0.1:50051
# Data directory for segments, WAL, and the manifest.
QUIVER_DATA_DIR=./data

# --- Encryption at rest (on by default) ---
# Path to the master-key file (mode 0600). Mutually exclusive with KMS.
# QUIVER_MASTER_KEY_FILE=/run/secrets/quiver-master-key
# Optional external KMS key URI (wraps/unwraps data-encryption keys).
# QUIVER_KMS_KEY_URI=

# --- TLS (required for non-loopback binds) ---
# QUIVER_TLS_CERT=/etc/quiver/tls/cert.pem
# QUIVER_TLS_KEY=/etc/quiver/tls/key.pem
# Explicit, unsafe opt-out to serve plaintext on a public interface (dev only).
# QUIVER_INSECURE=false

# --- Observability ---
# Log level: error|warn|info|debug|trace
QUIVER_LOG_LEVEL=info
# Prometheus metrics are served at /metrics on the HTTP listener.

# --- Limits ---
# Default per-key request rate limit (requests/second).
QUIVER_RATE_LIMIT_RPS=100
